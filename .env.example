# GEMINI_API_KEY: Required for Gemini embedding calls (resume/job vector search).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for resume parsing and job-match scoring (chat/JSON
# generation). Get a free key at https://console.groq.com/keys — no credit
# card required. Free tier: 14,400 requests/day for llama-3.1-8b-instant.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configurations (Retrieve from Supabase Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Secret token used to authorize automated Cron runs or manual pipelines
CRON_SECRET="your_custom_secure_cron_secret"

# Optional: Job board credentials (if a source's key is missing or its call fails, that source is simply skipped)
ADZUNA_APP_ID="your_adzuna_app_id"
ADZUNA_APP_KEY="your_adzuna_app_key"

# OPENWEBNINJA_API_KEY: JSearch job search, called directly against OpenWeb
# Ninja's own API (api.openwebninja.com), NOT via RapidAPI — this is a
# separate key system from a RapidAPI-issued JSearch key. Get one at
# https://app.openwebninja.com/api/jsearch. Free tier: 200 requests/month.
OPENWEBNINJA_API_KEY="your_openwebninja_api_key"

# JOOBLE_API_KEY: Job aggregator covering 69 countries, no documented rate
# cap on the free tier. Get one via the signup form at
# https://jooble.org/api/about (key is auto-issued, no manual approval).
JOOBLE_API_KEY="your_jooble_api_key"

